@model AtencionesApp.Models.ViewModels.AtencionOdontologiaFormViewModel
@using AtencionesApp.Models.Entities
@{
    ViewData["Title"] = "Editar Atención de Odontología";
    var tipos = ViewBag.Tipos as IEnumerable<TipoPrestacionOdontologia>;
    var diagnosticos = ViewBag.Diagnosticos as IEnumerable<Diagnostico>;
    var prestacionesJson = System.Text.Json.JsonSerializer.Serialize(
        Model.Prestaciones.Select(p => new { tipoPrestacionId = p.TipoPrestacionId, cantidad = p.Cantidad })
    );
    var valoracionJson = Model.Valoracion == null ? "null" : System.Text.Json.JsonSerializer.Serialize(Model.Valoracion);
}

<div class="page-header mb-4">
    <a href="/Pacientes/Details/@Model.PacienteId" class="btn-back">
        <i class="bi bi-arrow-left"></i> Volver
    </a>
    <h4 class="page-title mt-2">Editar Atención — Odontología</h4>
    <p class="page-sub">@Model.PacienteNombre</p>
</div>

<form asp-action="Edit" asp-route-id="@Model.Id" method="post" id="formAtencion">
    @Html.AntiForgeryToken()
    <input asp-for="PacienteId" type="hidden" />
    <input asp-for="PacienteNombre" type="hidden" />
    <input asp-for="PacienteFechaNacimiento" type="hidden" />
    <input type="hidden" id="odontogramaJson" name="odontogramaJson" value="[]" />

    <div id="datosCalculo" hidden
         data-fecha-nac="@Model.PacienteFechaNacimiento"
         data-prestaciones-edit="@prestacionesJson"
         data-valoracion-edit="@valoracionJson">
    </div>

    <div class="row g-4">

        <div class="col-lg-7">
            <div class="form-card mb-3">
                <p class="section-label">Datos de la atención</p>
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label-small">FECHA DE REGISTRO</label>
                        <p style="color: var(--content-text); font-weight: 600; margin: 4px 0 0;">@Model.Fecha.ToString("dd/MM/yyyy HH:mm")</p>
                    </div>
                    <input type="hidden" id="inputFecha" value="@Model.Fecha.ToString("yyyy-MM-ddTHH:mm")" />
                    <div class="col-6">
                        <label class="form-label-small">TIPO DE CONSULTA</label>
                        <select asp-for="TipoConsulta" class="form-select">
                            <option value="">— Seleccioná —</option>
                            <option value="1">1ª vez</option>
                            <option value="2">Ulterior</option>
                        </select>
                        <span asp-validation-for="TipoConsulta" class="text-danger small"></span>
                    </div>
                    <div class="col-6">
                        <label class="form-label-small">TIPO DE TURNO</label>
                        <select asp-for="TipoTurno" class="form-select">
                            <option value="">— Seleccioná —</option>
                            <option value="1">Ventanilla</option>
                            <option value="2">Profesional</option>
                            <option value="3">Demanda espontánea</option>
                            <option value="4">Interdisciplinario</option>
                        </select>
                        <span asp-validation-for="TipoTurno" class="text-danger small"></span>
                    </div>
                    <div class="col-6">
                        <label class="form-label-small">DIAGNÓSTICO</label>
                        <select asp-for="DiagnosticoId" class="form-select">
                            <option value="">— Seleccioná —</option>
                            @if (diagnosticos != null)
                            {
                                @foreach (var d in diagnosticos)
                                {
                                    <option value="@d.Id">@d.Codigo — @d.Descripcion</option>
                                }
                            }
                        </select>
                        <span asp-validation-for="DiagnosticoId" class="text-danger small"></span>
                    </div>
                    <div class="col-4">
                        <label class="form-label-small">EDAD</label>
                        <div class="edad-input-wrap">
                            <input asp-for="Edad" type="number" class="form-control edad-input" readonly />
                            <span class="edad-suffix">años</span>
                        </div>
                    </div>
                    <div class="col-8 d-flex align-items-end gap-4 pb-1">
                        @if (Model.PacienteSexo != "M")
                        {
                            <div class="form-check">
                                <input asp-for="Embarazada" class="form-check-input" type="checkbox" />
                                <label asp-for="Embarazada" class="form-check-label">Embarazada</label>
                            </div>
                        }
                        <div class="form-check">
                            <input asp-for="SinObraSocial" class="form-check-input" type="checkbox"
                                   disabled="@(Model.PacienteTieneObraSocial ? "disabled" : null)" />
                            <label asp-for="SinObraSocial" class="form-check-label">Sin Obra Social</label>
                        </div>
                    </div>
                    @if (Model.PacienteTieneObraSocial)
                    {
                        <div class="col-12">
                            <span class="form-label-small">OBRA SOCIAL</span>
                            <p style="color: var(--content-text); font-weight: 600; margin: 4px 0 0;">@Model.PacienteObraSocial</p>
                        </div>
                    }
                    <div class="col-12" id="osInlineContainer"
                         style="display: @(!Model.SinObraSocial && !Model.PacienteTieneObraSocial ? "block" : "none")">
                        <label class="form-label-small">OBRA SOCIAL DEL PACIENTE</label>
                        <input asp-for="NuevaObraSocial" type="text" class="form-control"
                               id="NuevaObraSocial"
                               placeholder="Ej: DOSEP, PAMI, OSDE..."
                               maxlength="100" />
                        <span class="form-text">Se guardará en el registro del paciente</span>
                    </div>
                    <div class="col-12">
                        <label class="form-label-small">OBSERVACIONES</label>
                        <textarea asp-for="Observaciones" class="form-control" rows="2"
                                  placeholder="Opcional — anotaciones clínicas relevantes..." maxlength="500"></textarea>
                    </div>
                </div>
            </div>

            <div class="form-card mb-3">
                <p class="section-label mb-3">Odontograma y Valoración CPO</p>
                <div class="row g-3 align-items-start">
                    <div class="col-7">
                        <div class="odontograma-card-clickable" data-bs-toggle="modal" data-bs-target="#modalOdontograma">
                            @await Html.PartialAsync("_Odontograma", new AtencionesApp.Models.ViewModels.OdontogramaViewModel
                            {
                                Modo = "card",
                                Estados = new()
                            })
                            <div class="odo-card-hint">Hacé clic para editar</div>
                        </div>
                    </div>
                    <div class="col-5">
                        <div class="cpo-form-grid">
                            <div class="cpo-form-group">
                                <label class="form-label-small">C PERM.</label>
                                <input id="Valoracion_CariesPerm" name="Valoracion.CariesPerm" type="number" class="form-control cpo-input" min="0" max="32"
                                       value="@(Model.Valoracion?.CariesPerm ?? 0)" readonly />
                            </div>
                            <div class="cpo-form-group">
                                <label class="form-label-small">P PERM.</label>
                                <input id="Valoracion_PerdidosPerm" name="Valoracion.PerdidosPerm" type="number" class="form-control cpo-input" min="0" max="32"
                                       value="@(Model.Valoracion?.PerdidosPerm ?? 0)" readonly />
                            </div>
                            <div class="cpo-form-group">
                                <label class="form-label-small">O PERM.</label>
                                <input id="Valoracion_ObturadosPerm" name="Valoracion.ObturadosPerm" type="number" class="form-control cpo-input" min="0" max="32"
                                       value="@(Model.Valoracion?.ObturadosPerm ?? 0)" readonly />
                            </div>
                            <div class="cpo-form-group">
                                <label class="form-label-small">c temp.</label>
                                <input id="Valoracion_CariesTemp" name="Valoracion.CariesTemp" type="number" class="form-control cpo-input" min="0" max="20"
                                       value="@(Model.Valoracion?.CariesTemp ?? 0)" readonly />
                            </div>
                            <div class="cpo-form-group">
                                <label class="form-label-small">e temp.</label>
                                <input id="Valoracion_ExtraccionTemp" name="Valoracion.ExtraccionTemp" type="number" class="form-control cpo-input" min="0" max="20"
                                       value="@(Model.Valoracion?.ExtraccionTemp ?? 0)" readonly />
                            </div>
                            <div class="cpo-form-group">
                                <label class="form-label-small">o temp.</label>
                                <input id="Valoracion_ObturadosTemp" name="Valoracion.ObturadosTemp" type="number" class="form-control cpo-input" min="0" max="20"
                                       value="@(Model.Valoracion?.ObturadosTemp ?? 0)" readonly />
                            </div>
                        </div>
                        <span class="form-text">Permanentes (C·P·O) · Temporarios (c·e·o)</span>
                    </div>
                </div>
            </div>

            <div class="form-card mb-3" id="resumenCard">
                <p class="section-label">Resumen de prestaciones seleccionadas</p>
                <div id="resumenLista">
                    <p class="text-muted small" id="resumenVacio">Ninguna prestación seleccionada aún</p>
                </div>
                <div id="errorPrestaciones" class="text-danger small mt-1" hidden></div>
            </div>

            <div id="prestacionesHidden"></div>

            <div class="form-actions-atencion">
                <button type="submit" class="btn-guardar-atencion">
                    <i class="bi bi-check-lg"></i> Guardar Atención
                </button>
                <a href="/Pacientes/Details/@Model.PacienteId" class="btn-cancelar-atencion">Cancelar</a>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="prestaciones-panel">
                <p class="section-label mb-3">Prestaciones de Odontología</p>
                @if (tipos != null && tipos.Any())
                {
                    @foreach (var tipo in tipos)
                    {
                        <div class="prestacion-item">
                            <label class="prestacion-label">
                                <input type="checkbox" class="prestacion-check" data-id="@tipo.Id" data-nombre="@tipo.NombrePrestacion" />
                                <span class="prestacion-nombre">@tipo.NombrePrestacion</span>
                            </label>
                            <input type="number" class="prestacion-cantidad" min="1" max="99" value="1" disabled />
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted small">No hay prestaciones cargadas</p>
                }
            </div>
        </div>

    </div>
</form>

<!-- Modal odontograma -->
<div class="modal fade modal-odontograma" id="modalOdontograma" tabindex="-1">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-grid-3x3-gap me-2"></i>Odontograma</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                @await Html.PartialAsync("_Odontograma", new AtencionesApp.Models.ViewModels.OdontogramaViewModel
                {
                    Modo = "editable",
                    Estados = Model.OdontogramaEstados
                })
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/odontologia.css" />
    <link rel="stylesheet" href="~/css/odontograma.css" />
}
@section Scripts {
    <script src="~/js/odontologia.js"></script>
    <script src="~/js/odontograma.js"></script>
}
