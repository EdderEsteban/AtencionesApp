<!DOCTYPE html>
<html lang="es" data-bs-theme="light">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Atenciones de Salud</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link
    href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600&display=swap"
    rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    @await RenderSectionAsync("Styles", required: false)
</head>

<body>

    <!-- SIDEBAR -->
    <aside id="sidebar">
        <div class="sidebar-brand">
            <div class="sidebar-brand-icon">
                <i class="bi bi-hospital"></i>
            </div>
            <div class="sidebar-brand-text">
                <div class="sidebar-brand-name">Atenciones de Salud</div>
                <div class="sidebar-brand-sub">San Luis</div>
            </div>
        </div>

        @{
            var instNombre = Context.Session.GetString("InstitucionActivaNombre");
            var instId = Context.Session.GetInt32("InstitucionActivaId");
            var rolActual = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "";
            var esAdmin = rolActual == "Administrador";
            var esDirector = rolActual == "Director";
            var esEnfermero = rolActual == "Enfermero";
            var esOdontologo = rolActual == "Odontólogo";
        }
        <div class="sidebar-inst">
            <div class="sidebar-inst-label">Institución activa</div>
            @if (esAdmin && instNombre == null)
            {
                <div class="sidebar-inst-name sidebar-inst-global">
                    <i class="bi bi-globe2"></i> Vista global
                </div>
            }
            else
            {
                <div class="sidebar-inst-name" title="@instNombre">@instNombre</div>
            }
            @if (User.Identity?.IsAuthenticated == true)
            {
                var urlCambio = esAdmin ? "/Account/SeleccionarInstitucionAdmin" : "/Account/SeleccionarInstitucion";
                <a href="@urlCambio" class="sidebar-inst-btn">
                    <i class="bi bi-arrow-left-right"></i>
                    @(esAdmin && instNombre == null ? "Seleccionar efector" : "Cambiar institución")
                </a>
            }
        </div>

        <div class="sidebar-section-label">Principal</div>
        <a href="/Home/Index" class="sidebar-nav-item active">
            <i class="bi bi-grid"></i> Inicio
        </a>
        <a href="/Pacientes" class="sidebar-nav-item">
            <i class="bi bi-people"></i> Pacientes
        </a>

        <div class="sidebar-divider"></div>

        <div class="sidebar-section-label">Atenciones</div>
        @if (esAdmin || esDirector || esEnfermero)
        {
            <a href="/AtencionesEnfermeria" class="sidebar-nav-item">
                <i class="bi bi-heart-pulse"></i> Enfermería
            </a>
        }
        @if (esAdmin || esDirector || esOdontologo)
        {
            <a href="/AtencionesOdontologia" class="sidebar-nav-item">
                <i class="bi bi-hospital"></i> Odontología
            </a>
        }

        @if (esAdmin)
        {
            <div class="sidebar-divider"></div>
            <div class="sidebar-section-label">Sistema</div>
            <a href="/Administracion/Usuarios" class="sidebar-nav-item">
                <i class="bi bi-gear"></i> Administración
            </a>
        }
    </aside>

    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <!-- NAVBAR -->
    <nav id="navbar">
        <button class="btn-hamburger" id="btnHamburger" title="Menú">
            <i class="bi bi-list"></i>
        </button>
        <div class="navbar-user-info">
            <div class="navbar-avatar" id="userAvatar"></div>
            <div>
                <div class="navbar-user-name">@User.Identity?.Name</div>
                <div class="navbar-user-role">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</div>
            </div>
        </div>

        <button class="theme-toggle" id="themeToggle" title="Cambiar tema">
            <i class="bi bi-sun"></i>
            <div class="theme-toggle-track">
                <div class="theme-toggle-thumb"></div>
            </div>
            <i class="bi bi-moon"></i>
        </button>

        <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
            <button type="submit" class="btn-icon" title="Cerrar sesión">
                <i class="bi bi-box-arrow-right"></i>
            </button>
        </form>
    </nav>

    <!-- CONTENIDO -->
    <main id="main-content">
        @RenderBody()
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/site.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
