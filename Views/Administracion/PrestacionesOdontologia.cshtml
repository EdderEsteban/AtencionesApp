@model List<AtencionesApp.Models.Entities.TipoPrestacionOdontologia>
@{
    ViewData["Title"] = "Prestaciones Odontología";
}
@section Styles {
    <link rel="stylesheet" href="~/css/administracion.css" />
}

@await Html.PartialAsync("_AdminNav")

<div class="page-header mb-4">
    <div>
        <h4 class="page-title">Prestaciones Odontología</h4>
        <p class="page-sub">@Model.Count prestaciones registradas</p>
    </div>
    <div class="d-flex gap-2">
        <a href="/Administracion/CrearPrestacionOdontologia" class="btn-admin-primary">
            <i class="bi bi-plus-lg"></i> Nueva prestación
        </a>
        <a href="/Administracion/Usuarios" class="btn-admin-back">
            <i class="bi bi-arrow-left"></i> Volver
        </a>
    </div>
</div>

@if (TempData["Exito"] != null)
{
    <div class="alert-admin-ok mb-3">
        <i class="bi bi-check-circle-fill"></i> @TempData["Exito"]
    </div>
}

<div class="admin-card">
    <table class="table-app">
        <tbody>
            @foreach (var p in Model)
            {
                <tr>
                    <td style="color: var(--content-text);">@p.NombrePrestacion</td>
                    <td>
                        <div class="table-actions">
                            <a href="/Administracion/EditarPrestacionOdontologia/@p.Id"
                               class="btn-icon" title="Editar">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form method="post"
                                  action="/Administracion/EliminarPrestacionOdontologia/@p.Id"
                                  onsubmit="return confirm('¿Eliminar prestación?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn-icon btn-icon-danger" title="Eliminar">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="2" class="text-center"
                        style="color: var(--sidebar-text); padding: 40px;">
                        No hay prestaciones registradas
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
