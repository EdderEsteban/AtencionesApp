@model AtencionesApp.Models.ViewModels.PrestacionOdontologiaFormViewModel
@{
    ViewData["Title"] = "Editar Prestación Odontología";
}
@section Styles {
    <link rel="stylesheet" href="~/css/administracion.css" />
}

<div class="page-header mb-4">
    <div>
        <h4 class="page-title">Editar Prestación</h4>
        <p class="page-sub">Odontología</p>
    </div>
    <a href="/Administracion/PrestacionesOdontologia" class="btn-admin-back">
        <i class="bi bi-arrow-left"></i> Volver
    </a>
</div>

<div class="form-card" style="max-width: 560px;">
    <form method="post" action="/Administracion/EditarPrestacionOdontologia/@Model.Id">
        @Html.AntiForgeryToken()
        <div class="col-12">
            <label class="form-label-small">NOMBRE DE LA PRESTACIÓN</label>
            <input asp-for="NombrePrestacion" class="form-control form-control-app" />
            <span asp-validation-for="NombrePrestacion" class="text-danger small"></span>
        </div>
        <div class="form-actions-admin mt-4">
            <button type="submit" class="btn-admin-primary">
                <i class="bi bi-check-lg"></i> Guardar cambios
            </button>
            <a href="/Administracion/PrestacionesOdontologia" class="btn-cancelar-admin">Cancelar</a>
        </div>
    </form>
</div>
