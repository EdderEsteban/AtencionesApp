@model List<AtencionesApp.Models.Entities.TipoPrestacionEnfermeria>
@{
    ViewData["Title"] = "Prestaciones Enfermería";
    var grupos = Model.GroupBy(p => p.Grupo).OrderBy(g => g.Key);
}
@section Styles {
    <link rel="stylesheet" href="~/css/administracion.css" />
}

@await Html.PartialAsync("_AdminNav")

<div class="page-header mb-4">
    <div>
        <h4 class="page-title">Prestaciones Enfermería</h4>
        <p class="page-sub">@Model.Count prestaciones en @grupos.Count() grupos</p>
    </div>
    <div class="d-flex gap-2">
        <a href="/Administracion/CrearPrestacionEnfermeria" class="btn-admin-primary">
            <i class="bi bi-plus-lg"></i> Nueva prestación
        </a>
        <a href="/Administracion/Usuarios" class="btn-admin-back">
            <i class="bi bi-arrow-left"></i> Volver
        </a>
    </div>
</div>

@if (TempData["Exito"] != null)
{
    <div class="alert-admin-ok mb-3">
        <i class="bi bi-check-circle-fill"></i> @TempData["Exito"]
    </div>
}

@foreach (var grupo in grupos)
{
    <div class="admin-card mb-3">
        <div class="admin-group-header">
            <span class="admin-group-title">@grupo.Key</span>
            <span class="admin-group-count">@grupo.Count()</span>
        </div>
        <table class="table-app">
            <tbody>
                @foreach (var p in grupo.OrderBy(x => x.NombrePrestacion))
                {
                    <tr>
                        <td style="color: var(--content-text);">@p.NombrePrestacion</td>
                        <td>
                            <div class="table-actions">
                                <a href="/Administracion/EditarPrestacionEnfermeria/@p.Id"
                                   class="btn-icon" title="Editar">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form method="post"
                                      action="/Administracion/EliminarPrestacionEnfermeria/@p.Id"
                                      onsubmit="return confirm('¿Eliminar prestación?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-icon btn-icon-danger" title="Eliminar">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (!Model.Any())
{
    <div class="admin-card text-center" style="padding: 40px; color: var(--sidebar-text);">
        No hay prestaciones registradas
    </div>
}
