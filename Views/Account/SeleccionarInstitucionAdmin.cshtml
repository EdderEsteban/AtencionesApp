@model List<AtencionesApp.Models.Entities.Institucion>
@{
    ViewData["Title"] = "Seleccionar Efector";
    Layout = null;
    var instActual = Context.Session.GetString("InstitucionActivaNombre");
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Seleccionar Efector — Atenciones de Salud</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tom-select@2.3.1/dist/css/tom-select.bootstrap5.min.css" />
    <style>
        body { background: #f1f5f9; min-height: 100vh; display: flex; align-items: center; justify-content: center; font-family: 'Segoe UI', sans-serif; }
        .sel-card { background: #fff; border-radius: 16px; padding: 36px 32px; width: 100%; max-width: 520px; box-shadow: 0 8px 32px rgba(0,0,0,0.10); }
        .sel-logo { width: 52px; height: 52px; border-radius: 14px; background: rgba(124,106,247,0.12); display: flex; align-items: center; justify-content: center; margin: 0 auto 20px; font-size: 1.5rem; color: #7c6af7; }
        .sel-title { font-size: 1.2rem; font-weight: 700; color: #1e293b; text-align: center; margin-bottom: 4px; }
        .sel-sub { font-size: 0.85rem; color: #64748b; text-align: center; margin-bottom: 24px; }
        .form-label-sm { font-size: 0.72rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: #64748b; margin-bottom: 6px; display: block; }
        .btn-primary-sel { display: flex; align-items: center; justify-content: center; gap: 7px; width: 100%; padding: 12px; background: #7c6af7; color: #fff; border: none; border-radius: 8px; font-size: 0.92rem; font-weight: 600; cursor: pointer; margin-top: 14px; transition: background 0.15s; }
        .btn-primary-sel:hover { background: #6d5ef0; }
        .btn-global { background: none; border: none; color: #7c6af7; font-size: 0.85rem; cursor: pointer; text-decoration: underline; }
        .divider-text { text-align: center; color: #94a3b8; font-size: 0.8rem; margin: 16px 0; }
    </style>
</head>
<body>
    <div class="sel-card">
        <div class="sel-logo"><i class="bi bi-hospital"></i></div>
        <div class="sel-title">Seleccionar efector</div>
        <div class="sel-sub">
            @if (instActual != null)
            {
                <span>Actualmente: <strong>@instActual</strong></span>
            }
            else
            {
                <span>Actualmente en <strong>vista global</strong> (todos los datos)</span>
            }
        </div>

        <form method="post" action="/Account/ConfirmarInstitucion">
            @Html.AntiForgeryToken()
            <label class="form-label-sm">EFECTOR</label>
            <select id="selectInstAdmin" name="institucionId">
                <option value="">Buscar institución…</option>
                @foreach (var inst in Model)
                {
                    <option value="@inst.Id">@inst.Nombre</option>
                }
            </select>
            <button type="submit" class="btn-primary-sel">
                <i class="bi bi-check-lg"></i> Trabajar en este efector
            </button>
        </form>

        <div class="divider-text">— o —</div>

        <form method="post" action="/Account/VolverAVistaGlobal" style="text-align: center;">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn-global">
                <i class="bi bi-globe2"></i> Volver a vista global
            </button>
        </form>

        <div style="text-align: center; margin-top: 14px;">
            <a href="/Home/Index" style="font-size: 0.82rem; color: #94a3b8;">Cancelar</a>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/tom-select@2.3.1/dist/js/tom-select.complete.min.js"></script>
    <script>
        new TomSelect('#selectInstAdmin', {
            maxOptions: 600,
            placeholder: 'Buscar institución…',
            create: false
        });
    </script>
</body>
</html>
