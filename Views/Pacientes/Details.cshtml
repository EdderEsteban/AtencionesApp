@model AtencionesApp.Models.Entities.Paciente
@{
    ViewData["Title"] = $"Ficha — {Model.Apellido}, {Model.Nombre}";
    var rol = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
}

<div class="page-header mb-4">
    <a href="/Pacientes" class="btn-back">
        <i class="bi bi-arrow-left"></i> Volver
    </a>
    <div class="d-flex justify-content-between align-items-center mt-2">
        <div>
            <h4 class="page-title">@Model.Apellido, @Model.Nombre</h4>
            <p class="page-sub">DNI @Model.DNI · @(Model.Sexo == "M" ? "Masculino" : Model.Sexo
                  == "F" ? "Femenino" : "No Especificado") · Nacido el
                @Model.FechaNacimiento.ToString("dd/MM/yyyy")</p>
            </div>
            @if (rol != "Director")
            {
                <a href="/Pacientes/Edit/@Model.Id" class="btn-primary-app">
                    <i class="bi bi-pencil"></i> Editar
                </a>
            }
        </div>
    </div>

    <div class="row g-4">

        <div class="col-md-4">
            <div class="form-card">
                <p class="section-label">Datos del paciente</p>
                <div class="dato-row">
                    <span class="dato-label">Domicilio</span>
                    <span class="dato-valor">@(Model.Domicilio ?? "—")</span>
                </div>
                <div class="dato-row">
                    <span class="dato-label">Teléfono</span>
                    <span class="dato-valor">@(Model.Telefono ?? "—")</span>
                </div>
                <div class="dato-row">
                    <span class="dato-label">Obra Social</span>
                    <span class="dato-valor">@(Model.ObraSocial ?? "Sin obra social")</span>
                </div>
            </div>
        </div>

        <div class="col-md-8">

            <div class="form-card mb-4">
                <p class="section-label">Atenciones de Enfermería
                    (@Model.AtencionesEnfermeria.Count)</p>
                    @if (!Model.AtencionesEnfermeria.Any())
                    {
                        <p class="text-muted small">Sin atenciones registradas</p>
                    }
                    else
                    {
                        <table class="table-app">
                            <thead>
                                <tr>
                                    <th>Fecha</th>
                                    <th>Tipo</th>
                                    <th>Edad</th>
                                    <th>Prestaciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var a in Model.AtencionesEnfermeria.OrderByDescending(x =>
        x.Fecha))
                                {
                                    <tr>
                                        <td>@a.Fecha.ToString("dd/MM/yyyy")</td>
                                        <td>@(a.TipoAtencion == 1 ? "Ambulatorio" : "Internado")</td>
                                        <td>@a.Edad años</td>
                                        <td class="td-prestaciones">
                                            @string.Join(", ", a.Prestaciones.Select(p =>
        p.TipoPrestacion.NombrePrestacion))
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>

                <div class="form-card">
                    <p class="section-label">Atenciones de Odontología
                        (@Model.AtencionesOdontologia.Count)</p>
                        @if (!Model.AtencionesOdontologia.Any())
                        {
                            <p class="text-muted small">Sin atenciones registradas</p>
                        }
                        else
                        {
                            <table class="table-app">
                                <thead>
                                    <tr>
                                        <th>Fecha</th>
                                        <th>Consulta</th>
                                        <th>Edad</th>
                                        <th>Prestaciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var a in Model.AtencionesOdontologia.OrderByDescending(x =>
            x.Fecha))
                                    {
                                        <tr>
                                            <td>@a.Fecha.ToString("dd/MM/yyyy")</td>
                                            <td>@(a.TipoConsulta == 1 ? "1ª vez" : "Ulterior")</td>
                                            <td>@a.Edad años</td>
                                            <td class="td-prestaciones">
                                                @string.Join(", ", a.Prestaciones.Select(p =>
            p.TipoPrestacion.NombrePrestacion))
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                    </div>

                </div>

            </div>